DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.example

DB_ENGINE=postgresql
DB_NAME=case_management
DB_USER=postgres
DB_PASSWORD=replace-with-your-postgres-password
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_CONNECT_TIMEOUT=5

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=replace-with-email
EMAIL_HOST_PASSWORD=replace-with-app-password
DEFAULT_FROM_EMAIL=replace-with-email
EMAIL_TIMEOUT=10

SIGNUP_ALLOWED_EMAIL_DOMAINS=hustudent.edu,hustudents.edu,hu.edu.et
STUDENT_EMAIL_DOMAINS=hustudent.edu,hustudents.edu
STAFF_EMAIL_DOMAINS=hu.edu.et
STAFF_EMAILS=
ADMIN_EMAILS=
SUPER_ADMIN_EMAILS=
ADMIN_EMAIL_DOMAINS=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
